# ============================================================
#  Ultimate AI Agent — Environment Variables (.env.example)
#  Copy this file to .env and fill in your values.
# ============================================================

# ── LLM Provider ──────────────────────────────────────────
# Options: ollama | openai | anthropic | gemini | groq
AGENT_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Security ───────────────────────────────────────────────
# AES-256 encryption key for persistent security engine.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_ENCRYPTION_KEY=

# API key for the Gateway server
AGENT_API_KEY=change-me-in-production

# ── OAuth & Integrations ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
ELEVENLABS_API_KEY=
NEWSAPI_KEY=
YOUTUBE_CREDENTIALS_FILE=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

HA_URL=http://homeassistant.local:8123
HA_TOKEN=

CRYPTO_EXCHANGE=binance
CRYPTO_API_KEY=
CRYPTO_API_SECRET=

# ── Gateway / API Server ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# CORS_ORIGINS is a comma-separated list of allowed origins. Leave empty for localhost defaults.
# Use * only for local development (automatically set when DEBUG=true).
CORS_ORIGINS=

# ── JWT Auth (Fix #21) ─────────────────────────────────────
# Secret for signing JWT tokens. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-jwt-secret

# ── Operational ───────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
HEADLESS_MODE=false
AGENT_DAEMON_MODE=false
PERSONALITY_MODE=default

# ── Database ──────────────────────────────────────────────
AGENT_DB_PATH=agent_database.db
AGENT_VECTOR_DB_PATH=agent_vector_db
